---
---
<section id="inicio" class="relative h-screen min-h-[600px] max-h-[900px] overflow-hidden">
  <div class="absolute inset-0">
    <img src={`${import.meta.env.BASE_URL}/images/hero-plaza.jpg`} alt="San Miguel de Allende" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-primary/70 via-primary/50 to-primary/80"></div>
  </div>

  <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
    <div class="fade-in">
      <p class="text-gold text-xs tracking-[0.3em] uppercase mb-3 font-light">San Miguel de Allende, Guanajuato</p>
    </div>
    <div class="fade-in">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-4 leading-tight">
        LA SERENA
      </h1>
    </div>
    <div class="fade-in">
      <p class="text-white/80 text-base md:text-lg max-w-xl mb-8 font-light leading-relaxed">
        Residencial de lujo que rinde homenaje al pintoresco pueblo mágico de San Miguel de Allende
      </p>
    </div>
    <div class="fade-in flex flex-col sm:flex-row gap-3">
      <a href="#proyecto" class="btn-gold bg-gold hover:bg-gold-dark text-white px-7 py-2.5 rounded text-xs tracking-widest uppercase transition-all">
        Descubre Más
      </a>
      <a href="#contacto" class="border border-white/40 hover:border-gold text-white hover:text-gold px-7 py-2.5 rounded text-xs tracking-widest uppercase transition-all">
        Agenda tu Visita
      </a>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </div>
</section>
