---
---
<section id="contacto" class="py-20 bg-primary">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12">
      <div class="fade-in">
        <p class="text-gold text-sm tracking-[0.2em] uppercase mb-3">Contáctanos</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Agenda tu Visita</h2>
        <div class="w-14 h-0.5 bg-gold mb-6"></div>
        <p class="text-white/70 mb-8 text-sm leading-relaxed">
          Descubre todo lo que La Serena Residencial tiene para ti. Nuestro equipo estará encantado de atenderte.
        </p>

        <div class="space-y-5">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/50 text-xs">Teléfono</p>
              <p class="text-white text-sm font-medium">55 2748 6478 / 56 2418 3152</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/50 text-xs">Dirección</p>
              <p class="text-white text-sm font-medium">Carretera San Miguel - Celaya 41</p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/50 text-xs">Email</p>
              <p class="text-white text-sm font-medium">info@badi108.com</p>
            </div>
          </div>
        </div>
      </div>

      <div class="fade-in">
        <form class="bg-white rounded-xl p-7 shadow-2xl">
          <div class="mb-4">
            <label class="block text-xs font-medium text-dark mb-1.5">Nombre Completo</label>
            <input type="text" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" placeholder="Tu nombre" />
          </div>
          <div class="mb-4">
            <label class="block text-xs font-medium text-dark mb-1.5">Email</label>
            <input type="email" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" placeholder="tu@email.com" />
          </div>
          <div class="mb-4">
            <label class="block text-xs font-medium text-dark mb-1.5">Teléfono</label>
            <input type="tel" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm" placeholder="Tu teléfono" />
          </div>
          <div class="mb-4">
            <label class="block text-xs font-medium text-dark mb-1.5">¿Qué te interesa?</label>
            <select class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all text-sm">
              <option>Pent House</option>
              <option>Casa</option>
              <option>Departamento</option>
              <option>Más información</option>
            </select>
          </div>
          <div class="mb-5">
            <label class="block text-xs font-medium text-dark mb-1.5">Mensaje</label>
            <textarea rows="3" class="w-full px-3 py-2.5 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none text-sm" placeholder="Cuéntanos qué necesitas..."></textarea>
          </div>
          <button type="submit" class="w-full btn-gold bg-primary hover:bg-primary-dark text-white py-3 rounded-lg font-medium tracking-wide transition-all text-sm">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
