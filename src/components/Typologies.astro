---
const typologies = [
  {
    name: 'UMARÁN',
    type: 'Casa',
    area: '167.41 m²',
    image: 'images/proto-1.jpg',
    specs: ['Sala Comedor', 'Cocina', 'Terraza', 'Lavado'],
  },
  {
    name: 'STO. DOMINGO',
    type: 'Pent House',
    area: '226.63 m²',
    image: 'images/proto-2.jpg',
    specs: ['4 Recámaras', '4 Baños', 'Roof Garden', 'Terraza'],
  },
  {
    name: 'SAN FRANCISCO',
    type: 'Departamento',
    area: '142.80 m²',
    image: 'images/proto-3.jpg',
    specs: ['3 Recámaras', '3 Baños', 'Balcón', 'Estac.'],
  },
  {
    name: 'LA CONCHA',
    type: 'Casa',
    area: '198.50 m²',
    image: 'images/proto-4.jpg',
    specs: ['3 Recámaras', '3.5 Baños', 'Jardín', 'Terraza'],
  },
];
---
<section id="tipologias" class="py-20 bg-dark">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14 fade-in">
      <p class="text-gold text-sm tracking-[0.2em] uppercase mb-3">Diseñados para Ti</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Nuestros Prototipos</h2>
      <div class="w-14 h-0.5 bg-gold mx-auto mb-6"></div>
      <p class="text-gray-400 max-w-xl mx-auto text-sm leading-relaxed">
        Detrás de la artesanía que tiene cada puerta, descubrirás prototipos diseñados minuciosamente para que tú y tu familia reciban la comodidad que se merecen.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {typologies.map((typo) => (
        <div class="fade-in card-hover bg-white/5 backdrop-blur-sm rounded-xl overflow-hidden border border-white/10 group">
          <div class="relative h-52 overflow-hidden">
            <img src={import.meta.env.BASE_URL + "/" + typo.image} alt={typo.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            <div class="absolute top-3 right-3 bg-gold text-white text-[10px] px-2.5 py-1 rounded-full font-semibold uppercase tracking-wider">
              {typo.type}
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-white mb-1">{typo.name}</h3>
            <p class="text-gold text-xl font-bold mb-3">{typo.area}</p>
            <div class="flex flex-wrap gap-1.5">
              {typo.specs.map((spec) => (
                <span class="text-[10px] bg-white/10 text-white/60 px-2 py-0.5 rounded-full">{spec}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-14 fade-in">
      <div class="relative rounded-xl overflow-hidden">
        <img src={import.meta.env.BASE_URL + "/images/prototipos.jpg"} alt="Interiores La Serena" class="w-full h-64 md:h-80 object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/40 to-transparent flex items-end">
          <div class="p-6 md:p-10">
            <p class="text-gold text-xs tracking-[0.2em] uppercase mb-2">Arquitectura Colonial</p>
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Encanto y Confort</h3>
            <p class="text-white/70 max-w-lg text-sm">Enamórate de la arquitectura colonial que expone cada uno de los rincones de La Serena.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
